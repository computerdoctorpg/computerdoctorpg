VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OBAVEZNO za kreiranje/brisanje operatera (Admin API — ne šalje email)
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stara baza (Horizon) - za export tiketa
OLD_SUPABASE_URL=https://wogcdrvkthkjaatwzknv.supabase.co
OLD_EXPORT_EMAIL=prodaja@computer-doctor.me
OLD_EXPORT_PASSWORD=your-live-password

# Nova baza (nakon Hostinger Supabase wizarda)
# NEW_SUPABASE_URL=https://new-project.supabase.co

# ============================================================
# SMTP — slanje prijemnice/otpremnice klijentu na email
# (Hostinger: smtp.hostinger.com, port 465, SSL)
# ============================================================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=servis@computerdoctor.in
# Hostinger: koristi base64 umjesto SMTP_PASS (izbjegava problem sa #)
# Generiši: node -e "console.log(Buffer.from('tvoja-lozinka').toString('base64'))"
SMTP_PASS_B64=your-base64-password
SMTP_FROM=servis@computerdoctor.in
SMTP_FROM_NAME=Computer Doctor

# Link u emailu za zaposlene (opciono, default: https://www.computerdoctor.in)
APP_LOGIN_URL=https://www.computerdoctor.in
